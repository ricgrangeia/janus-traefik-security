# ── Traefik API ───────────────────────────────────────────────────────────
# Base URL of Traefik's internal API (no trailing slash).
# Janus reaches Traefik by container name over the shared "proxy-network".
TRAEFIK_API_URL=http://traefik:8080

# ── Janus Server ─────────────────────────────────────────────────────────
# Port Janus listens on inside the container.
JANUS_PORT=9090

# ── Pulse Monitor ─────────────────────────────────────────────────────────
# Combined 4xx+5xx error-rate fraction that triggers a Pulse alert (0.0–1.0).
# Example: 0.10 = alert when more than 10 % of requests are errors.
JANUS_ALERT_THRESHOLD=0.10

# ── AI Analyst (optional — leave VLLM_API_URL empty to disable) ───────────
# Base URL of the vLLM server exposing an OpenAI-compatible API.
VLLM_API_URL=http://vllm:8000
# Model name as registered in vLLM (must match --model flag used at startup).
VLLM_MODEL=qwen2.5-7b-instruct
# Bearer token sent as "Authorization: Bearer <key>". Leave empty if not required.
VLLM_API_KEY=
# How often (seconds) the AI audit background worker runs. Minimum: 10.
JANUS_AI_INTERVAL=60

# ── AI Context & Observability ────────────────────────────────────────────
# Deployment label sent to Janus-AI so it can distinguish intentional from
# accidental exposure (e.g. staging may expose more than production).
JANUS_ENV=production
# Comma-separated list of middleware names that are considered trusted/secure
# in this environment. Janus-AI uses this to detect architectural drift.
JANUS_KNOWN_MIDDLEWARES=traefik-auth,authentik,crowdsec
# Path inside the container where AI audit traces (JSONL) are written.
# Each line is one JSON record with token counts, latency, and severity.
# Map a host volume in docker-compose to persist across restarts.
JANUS_AI_TRACE_PATH=/logs/ai_audit_trace.json

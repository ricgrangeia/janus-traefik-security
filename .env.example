# ── Traefik API ───────────────────────────────────────────────────────────
# Base URL of Traefik's internal API (no trailing slash).
# Janus reaches Traefik by container name over the shared "proxy-network".
TRAEFIK_API_URL=http://traefik:8080

# ── Janus Server ─────────────────────────────────────────────────────────
# Port Janus listens on inside the container.
JANUS_PORT=9090

# ── Pulse Monitor ─────────────────────────────────────────────────────────
# Combined 4xx+5xx error-rate fraction that triggers a Pulse alert (0.0–1.0).
# Example: 0.10 = alert when more than 10 % of requests are errors.
JANUS_ALERT_THRESHOLD=0.10

# ── AI Analyst (optional — leave VLLM_API_URL empty to disable) ───────────
# Base URL of the vLLM server exposing an OpenAI-compatible API.
VLLM_API_URL=http://vllm:8000
# Model name as registered in vLLM (must match --model flag used at startup).
VLLM_MODEL=qwen2.5-7b-instruct
# Bearer token sent as "Authorization: Bearer <key>". Leave empty if not required.
VLLM_API_KEY=
# How often (seconds) the AI audit background worker runs. Minimum: 10.
JANUS_AI_INTERVAL=60

# ── Telegram Alerts (optional — leave TELEGRAM_BOT_TOKEN empty to disable) ───
# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=
# Target chat or channel ID (use @channelusername or numeric ID).
TELEGRAM_CHAT_ID=
# Minimum AI overall severity (0-10) that triggers a bot_scan Telegram alert.
TELEGRAM_SEVERITY_THRESHOLD=8

# ── AI Context & Observability ────────────────────────────────────────────
# Deployment label sent to Janus-AI so it can distinguish intentional from
# accidental exposure (e.g. staging may expose more than production).
JANUS_ENV=production
# Comma-separated list of middleware names that are considered trusted/secure
# in this environment. Janus-AI uses this to detect architectural drift.
JANUS_KNOWN_MIDDLEWARES=traefik-auth,authentik,crowdsec
# Path inside the container where AI audit traces (JSONL) are written.
# Each line is one JSON record with token counts, latency, and severity.
# Map a host volume in docker-compose to persist across restarts.
JANUS_AI_TRACE_PATH=/logs/ai_audit_trace.json
# Path where audit history (JSON array) is stored for trend analysis.
JANUS_HISTORY_PATH=/logs/audit_history.json
# Path to the policies JSON file. Mount a custom file to override defaults.
JANUS_POLICIES_PATH=/configs/policies.json

# ── Active Defense (Shield) ──────────────────────────────────────────────
# Path inside the container where Janus writes the Traefik dynamic-config YAML
# that blocks attacker IPs. Mount the same directory into Traefik and enable
# the file provider to activate the janus-shield middleware.
JANUS_SHIELD_PATH=/rules/blocklist.yaml
# AI severity threshold (1-10) above which a bot_scan alert with a known IP
# triggers an automatic block. Default 10 = only block at critical severity.
JANUS_AUTO_BLOCK_MIN=10
# Path to Traefik's JSON-format access log. Janus tails this file to monitor
# post-ban activity for blocked IPs. The file must be on a shared volume:
#   docker-compose.yml: - /opt/traefik/logs:/logs (same mount on Traefik side)
#   Traefik flag: --accesslog.filepath=/logs/access.log --accesslog.format=json
JANUS_ACCESS_LOG_PATH=/logs/access.log

# ── Persistent Memory (SQLite) ────────────────────────────────────────────
# Path inside the container for the SQLite database. The directory must be
# backed by a host volume (see docker-compose.yml). Set to empty string to
# fall back to the legacy JSON history file (JANUS_HISTORY_PATH).
JANUS_DB_PATH=/app/data/janus.db
